# Concierge AI — env contract (placeholder values only)
#
# Production secret/API/webhook 실값은 코드/문서/PR 본문 어디에도 commit 금지
# (FINAL_ALIGNMENT §D-12). 본 파일은 키와 형태만 기록한다.

# Origin allowlist — 콤마 구분, scheme 포함
CONCIERGE_ALLOWED_ORIGINS=https://staging.concierge.motionlabs.kr,https://concierge.motionlabs.kr

# Vite client-side env (widget 빌드 시 inline)
VITE_CONCIERGE_ENVIRONMENT=production
VITE_CONCIERGE_ALLOWED_ORIGINS=https://staging.concierge.motionlabs.kr,https://concierge.motionlabs.kr
VITE_CONCIERGE_EMBED_BASE=https://staging.concierge.motionlabs.kr

# Anthropic — server-only, /api/concierge proxy에서 사용
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_PROMPT_CACHE=true

# Supabase — server-only (RLS 통과용 service role)
SUPABASE_URL=https://PLACEHOLDER.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER
SUPABASE_ANON_KEY=PLACEHOLDER

# Slack — staging webhook only. production webhook은 Phase 6 KPI 인프라까지 절대 commit 금지.
SLACK_WEBHOOK_URL_STAGING=https://hooks.slack.com/services/PLACEHOLDER

# Cost cap — 월 USD ceiling, 초과 시 Vercel cron이 nightly 검증 중지 알림
CONCIERGE_COST_CAP_USD=1000
