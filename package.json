{
  "name": "conciergeai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:widget",
    "build:embed": "npm run build --workspace=@conciergeai/embed",
    "build:widget": "npm run build --workspace=@conciergeai/widget",
    "build:admin": "npm run build --workspace=@conciergeai/admin",
    "build:vercel:widget": "node scripts/build-widget-with-embed.mjs",
    "design-polish:verify": "node scripts/verify-design-polish-contract.mjs",
    "dev:widget": "npm run dev --workspace=@conciergeai/widget",
    "dev:admin": "npm run dev --workspace=@conciergeai/admin",
    "lint": "tsc --noEmit -p tsconfig.json --pretty false",
    "pr:evidence:validate": "node scripts/validate-pr-evidence.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "security:scan:diff": "node scripts/security-scan.mjs --mode diff",
    "security:scan:history": "node scripts/security-scan.mjs --mode history --commits 20",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "framer-motion": "^11.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  }
}
